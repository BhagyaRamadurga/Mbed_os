digraph set_led1_state {
  rankdir=TB;
  splines=ortho;
  nodesep=0.45;
  ranksep=0.95;
  pad=0.25;
  bgcolor="#FFFFFF";
  graph [fontname="Helvetica"];
  node [fontname="Helvetica", fontsize=11];
  edge [fontname="Helvetica", fontsize=10, arrowsize=0.8];

  subgraph cluster_set_led1_state {
    label="set_led1_state";
    fontcolor="#333333";
    style="rounded";
    color="#FFFFFF";
    penwidth=1.2;
    margin=12;
    fillcolor="#FFFFFF";
    bgcolor="#FFFFFF";

    set_led1_state_START [shape=oval, style=filled, fillcolor="#FFFFFF", fontcolor="#333333", label="START\nset_led1_state()", width=2.4, penwidth=1.4];
    set_led1_state_END [shape=oval, style=filled, fillcolor="#FFFFFF", fontcolor="#333333", label="set_led1_state_end", width=1.8, penwidth=1.2];
    set_led1_state_N1 [shape=box, label="Set LED state based on\\n'on' parameter", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    set_led1_state_START -> set_led1_state_N1;
    set_led1_state_N1 -> set_led1_state_END;
  }
}