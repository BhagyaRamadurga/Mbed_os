digraph blink_led1 {
  rankdir=TB;
  splines=ortho;
  nodesep=0.45;
  ranksep=0.95;
  pad=0.25;
  bgcolor="#D32F2F";
  graph [fontname="Helvetica"];
  node [fontname="Helvetica", fontsize=11];
  edge [fontname="Helvetica", fontsize=10, arrowsize=0.8];

  subgraph cluster_blink_led1 {
    label="blink_led1";
    fontcolor="#D32F2F";
    fontcolor="#333333";
    style="rounded";
    color="#D32F2F";
    penwidth=3.0;
    margin=12;
    fillcolor="#D32F2F";
    bgcolor="#D32F2F";

    blink_led1_START [shape=oval, style=filled, fillcolor="#D32F2F", fontcolor="#333333", label="START\nblink_led1()", width=2.4, penwidth=1.4];
    blink_led1_END [shape=oval, style=filled, fillcolor="#D32F2F", fontcolor="#333333", label="blink_led1_end", width=1.8, penwidth=1.2];
    blink_led1_N1 [shape=box, label="toggle LED state", style=filled, fillcolor="#D32F2F", fontcolor="#333333", width=2.1];
    blink_led1_START -> blink_led1_N1;
    blink_led1_N1 -> blink_led1_END;
  }
}