digraph main {
  rankdir=TB;
  splines=ortho;
  nodesep=0.45;
  ranksep=0.95;
  pad=0.25;
  bgcolor="#FFFFFF";
  graph [fontname="Helvetica"];
  node [fontname="Helvetica", fontsize=11];
  edge [fontname="Helvetica", fontsize=10, arrowsize=0.8];

  subgraph cluster_main {
    label="main";
    fontcolor="#333333";
    style="rounded";
    color="#FFFFFF";
    penwidth=1.2;
    margin=12;
    fillcolor="#FFFFFF";
    bgcolor="#FFFFFF";

    main_START [shape=oval, style=filled, fillcolor="#FFFFFF", fontcolor="#333333", label="START\nmain()", width=2.4, penwidth=1.4];
    main_END [shape=oval, style=filled, fillcolor="#FFFFFF", fontcolor="#333333", label="main_end", width=1.8, penwidth=1.2];
    main_N1 [shape=box, label="Initialize loop_started to\\nfalse", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N2 [shape=box, label="Print program start\\nmessage", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N3 [shape=diamond, label="[COMPILE] defined(LED1)?", width=3.2, height=0.9, style=filled, fillcolor="#FFFFFF", fontcolor="#333333", penwidth=1.1];
    main_N4 [shape=box, label="Initialize DigitalOut\\nled(LED1)", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N5 [shape=box, label="Read previous_led_state\\nfrom led", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N6 [shape=diamond, label="[RUNTIME] previous_led_state?", width=3.2, height=0.9, style=filled, fillcolor="#FFFFFF", fontcolor="#333333", penwidth=1.1];
    main_N7 [shape=box, label="Print LED1 starts as ON", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N8 [shape=box, label="Print LED1 starts as OFF", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N9 [shape=diamond, label="[COMPILE] defined(BUTTON1)?", width=3.2, height=0.9, style=filled, fillcolor="#FFFFFF", fontcolor="#333333", penwidth=1.1];
    main_N10 [shape=box, label="Initialize DigitalIn\\nbutton(BUTTON1, PullUp)", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N11 [shape=box, label="Initialize\\nprevious_pressed to false", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N12 [shape=box, label="Initialize\\nbutton_press_count to 0", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N13 [shape=diamond, label="[RUNTIME] !loop_started?", width=3.2, height=0.9, style=filled, fillcolor="#FFFFFF", fontcolor="#333333", penwidth=1.1];
    main_N14 [shape=box, label="Print main loop started\\nmessage", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N15 [shape=box, label="Set loop_started to true", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N16 [shape=diamond, label="[RUNTIME] button_press_count >\\n0?", width=3.2, height=0.9, style=filled, fillcolor="#FFFFFF", fontcolor="#333333", penwidth=1.1];
    main_N17 [shape=box, label="Print total BUTTON1\\npresses", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N18 [shape=diamond, label="[COMPILE] defined(LED1) &&\\ndefined(BUTTON1)?", width=3.2, height=0.9, style=filled, fillcolor="#FFFFFF", fontcolor="#333333", penwidth=1.1];
    main_N19 [shape=box, label="Read pressed from button", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N20 [shape=box, style="rounded,filled", fillcolor="#FFFFFF", fontcolor="#333333", label="call set_led1_state(led,\\npressed)", penwidth=1.2, width=2.1];
    main_N21 [shape=diamond, label="[RUNTIME] pressed &&\\n!previous_pressed?", width=3.2, height=0.9, style=filled, fillcolor="#FFFFFF", fontcolor="#333333", penwidth=1.1];
    main_N22 [shape=box, label="Increment\\nbutton_press_count and\\nprint BUTTON1 press count", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N23 [shape=box, label="Set previous_pressed to\\npressed", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N24 [shape=box, style="rounded,filled", fillcolor="#FFFFFF", fontcolor="#333333", label="call ThisThread::sleep_for(BU\\nTTON_POLL_RATE)", penwidth=1.2, width=2.1];
    main_N25 [shape=diamond, label="[COMPILE] defined(LED1)?", width=3.2, height=0.9, style=filled, fillcolor="#FFFFFF", fontcolor="#333333", penwidth=1.1];
    main_N26 [shape=box, label="Read current_led_state\\nfrom led", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N27 [shape=diamond, label="[RUNTIME] current_led_state !=\\nprevious_led_state?", width=3.2, height=0.9, style=filled, fillcolor="#FFFFFF", fontcolor="#333333", penwidth=1.1];
    main_N28 [shape=box, label="Print LED1 state and\\nupdate previous_led_state", style=filled, fillcolor="#FFFFFF", fontcolor="#333333", width=2.1];
    main_N29 [shape=box, style="rounded,filled", fillcolor="#FFFFFF", fontcolor="#333333", label="call ThisThread::sleep_for(BL\\nINKING_RATE)", penwidth=1.2, width=2.1];
    main_START -> main_N1;
    main_N1 -> main_N2;
    main_N2 -> main_N3;
    main_N3 -> main_N4 [label="Yes", penwidth=1.4];
    main_N3 -> main_N10 [label="No", penwidth=1.4];
    main_N4 -> main_N5;
    main_N5 -> main_N6;
    main_N6 -> main_N7 [label="Yes", penwidth=1.4];
    main_N6 -> main_N8 [label="No", penwidth=1.4];
    main_N7 -> main_N8;
    main_N8 -> main_N9;
    main_N9 -> main_N10 [label="Yes", penwidth=1.4];
    main_N9 -> main_N23 [label="No", penwidth=1.4];
    main_N10 -> main_N11;
    main_N11 -> main_N12;
    main_N12 -> main_N13;
    main_N13 -> main_N14 [label="Yes", penwidth=1.4];
    main_N13 -> main_N15 [label="No", penwidth=1.4];
    main_N14 -> main_N15;
    main_N15 -> main_N16;
    main_N16 -> main_N17 [label="Yes", penwidth=1.4];
    main_N16 -> main_N23 [label="No", penwidth=1.4];
    main_N17 -> main_N18;
    main_N18 -> main_N19 [label="Yes", penwidth=1.4];
    main_N18 -> main_N23 [label="No", penwidth=1.4];
    main_N19 -> main_N20;
    main_N20 -> main_N21;
    main_N21 -> main_N22 [label="Yes", penwidth=1.4];
    main_N21 -> main_N23 [label="No", penwidth=1.4];
    main_N22 -> main_N23;
    main_N23 -> main_N24;
    main_N24 -> main_N25;
    main_N25 -> main_N26 [label="Yes", penwidth=1.4];
    main_N25 -> main_N30 [label="No", penwidth=1.4];
    main_N26 -> main_N27;
    main_N27 -> main_N28 [label="Yes", penwidth=1.4];
    main_N27 -> main_N30 [label="No", penwidth=1.4];
    main_N28 -> main_N29;
    main_N29 -> main_END;
  }
}